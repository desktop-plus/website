---
import { Icon } from "astro-icon/components";
import { REPO_URL } from "../consts";
---

<header class="sticky top-0 z-50 border-b border-border/70 bg-canvas/80 backdrop-blur-md">
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-5 sm:px-8" aria-label="Primary">
    <a
      href="#top"
      class="flex items-center gap-2.5 rounded-md focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand-400"
    >
      <img src="/icon.png" class="h-8 w-8" alt="" width="32" height="32" />
      <span class="text-[15px] font-semibold tracking-tight text-white">
        GH Desktop <span class="text-gradient">Plus</span>
      </span>
    </a>

    <div class="flex items-center gap-1 sm:gap-2">
      <a href="#features" class="hidden rounded-md px-3 py-2 text-sm text-fg-muted transition hover:text-fg sm:inline-block">Features</a>
      <a href="#install" class="hidden rounded-md px-3 py-2 text-sm text-fg-muted transition hover:text-fg sm:inline-block">Install</a>
      <a
        href={REPO_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="ml-1 inline-flex items-center gap-2 rounded-lg border border-border bg-surface px-3.5 py-2 text-sm font-medium text-fg transition hover:border-brand-500/60 hover:bg-surface-muted focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-400"
      >
        <Icon name="octicon:mark-github-16" class="h-[18px] w-[18px]" />
        <span class="hidden sm:inline">GitHub</span>
      </a>
    </div>
  </nav>
</header>
