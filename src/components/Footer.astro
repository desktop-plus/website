---
import { Icon } from "astro-icon/components";
import { ISSUES_URL, RELEASES_URL, REPO_URL } from "../consts";
const year = new Date().getFullYear();
---

<!-- Final CTA -->
<section class="border-t border-border/60">
  <div class="relative mx-auto max-w-4xl overflow-hidden px-5 py-20 text-center sm:px-8">
    <div class="pointer-events-none absolute inset-0 glow" aria-hidden="true"></div>
    <div class="relative">
      <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Ready to give it a try?</h2>
      <p class="mx-auto mt-4 max-w-xl text-balance text-fg-muted">
        Free and open source, available on every major platform. Star the repo to follow along, or install it in one command.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href="#install"
          class="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-brand-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-brand-900/40 transition hover:bg-brand-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-400 sm:w-auto"
        >
          <Icon name="octicon:download-16" class="h-[18px] w-[18px]" />
          Install now
        </a>
        <a
          href={REPO_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex w-full items-center justify-center gap-2 rounded-lg border border-border bg-surface px-6 py-3 text-sm font-semibold text-fg transition hover:border-brand-500/60 hover:bg-surface-muted focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-400 sm:w-auto"
        >
          <Icon name="octicon:mark-github-16" class="h-[18px] w-[18px]" />
          Star on GitHub
        </a>
      </div>
    </div>
  </div>
</section>

<footer class="border-t border-border/60 bg-canvas-inset/60">
  <div class="mx-auto max-w-6xl px-5 py-14 sm:px-8">
    <div class="flex flex-col justify-between gap-10 sm:flex-row">
      <div class="max-w-sm">
        <div class="flex items-center gap-2.5">
          <img src="/icon.png" class="h-7 w-7" alt="" width="28" height="28" />
          <span class="text-[15px] font-semibold tracking-tight text-white">
            GH Desktop <span class="text-gradient">Plus</span>
          </span>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-fg-muted">
          An up-to-date fork of GitHub Desktop with extra features and improvements, on Windows, macOS and Linux.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-10 sm:gap-16">
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-wider text-fg-subtle">Project</h3>
          <ul class="mt-4 space-y-3 text-sm">
            <li>
              <a href={REPO_URL} target="_blank" rel="noopener noreferrer" class="text-fg-muted transition hover:text-fg">GitHub repository</a>
            </li>
            <li>
              <a href={RELEASES_URL} target="_blank" rel="noopener noreferrer" class="text-fg-muted transition hover:text-fg">Releases</a>
            </li>
            <li>
              <a href={ISSUES_URL} target="_blank" rel="noopener noreferrer" class="text-fg-muted transition hover:text-fg">Report an issue</a>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-xs font-semibold uppercase tracking-wider text-fg-subtle">Get started</h3>
          <ul class="mt-4 space-y-3 text-sm">
            <li>
              <a href="#features" class="text-fg-muted transition hover:text-fg">Features</a>
            </li>
            <li>
              <a href="#install" class="text-fg-muted transition hover:text-fg">Install</a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-2 border-t border-border/60 pt-8 text-xs text-fg-subtle sm:flex-row sm:items-center sm:justify-between">
      <p>
        © {year} Desktop Plus contributors · MIT-licensed · <b>Not affiliated with or endorsed by GitHub, Inc.</b>
      </p>
      <p>
        App icon adapted from{" "}
        <a
          href="https://lucide.dev/icons/git-branch-plus"
          target="_blank"
          rel="noopener noreferrer"
          class="underline underline-offset-2 hover:text-fg-muted">Lucide</a
        >.
      </p>
    </div>
  </div>
</footer>
