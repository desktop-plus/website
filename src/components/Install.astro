---
import { Icon } from "astro-icon/components";
import CodeBlock from "./CodeBlock.astro";
import { RELEASES_URL, FLATHUB_URL } from "../consts";

// --- Linux command blocks (authored to match the project README) ---
const apt = `sudo curl https://gpg.desktop-plus.org/public.key | sudo gpg --dearmor -o /usr/share/keyrings/desktop-plus.gpg
echo "deb [arch=amd64,arm64 signed-by=/usr/share/keyrings/desktop-plus.gpg] https://apt.desktop-plus.org/ stable main" | sudo tee /etc/apt/sources.list.d/desktop-plus.list
sudo apt update
sudo apt install desktop-plus`;

const dnf = `sudo rpm --import https://gpg.desktop-plus.org/public.key
echo -e "[desktop-plus]\\nname=Desktop Plus\\nbaseurl=https://rpm.desktop-plus.org/\\nenabled=1\\ngpgcheck=1\\nrepo_gpgcheck=1\\ngpgkey=https://gpg.desktop-plus.org/public.key" | sudo tee /etc/yum.repos.d/desktop-plus.repo
sudo dnf check-update --refresh
sudo dnf install desktop-plus`;

const zypper = `sudo rpm --import https://gpg.desktop-plus.org/public.key
echo -e "[desktop-plus]\\nname=Desktop Plus\\nbaseurl=https://rpm.desktop-plus.org/\\nenabled=1\\ngpgcheck=1\\nrepo_gpgcheck=1\\ngpgkey=https://gpg.desktop-plus.org/public.key" | sudo tee /etc/zypp/repos.d/desktop-plus.repo
sudo zypper refresh
sudo zypper install desktop-plus`;
---

<section id="install" class="scroll-mt-20 border-t border-border/60">
  <div class="mx-auto max-w-4xl px-5 py-20 sm:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Install in one command</h2>
      <p class="mt-4 text-balance text-fg-muted">
        Pick your platform. Installing through a package manager is recommended, since the app doesn't auto-update on its own.
      </p>
    </div>

    <!-- OS tabs -->
    <div class="mt-10 flex flex-wrap justify-center gap-2" role="tablist" aria-label="Operating system">
      {
        [
          // Windows' logo fills its whole viewBox, so it reads larger than the
          // others at the same box size; nudge it down to balance optically.
          { id: "windows", label: "Windows", icon: "simple-icons:windows", iconClass: "h-3.5 w-3.5" },
          { id: "macos", label: "macOS", icon: "simple-icons:apple", iconClass: "h-4.5 w-4.5" },
          { id: "linux", label: "Linux", icon: "simple-icons:linux", iconClass: "h-4.5 w-4.5" },
        ].map((os, i) => (
          <button
            type="button"
            role="tab"
            data-tab-group="os"
            data-tab={os.id}
            aria-selected={i === 0 ? "true" : "false"}
            class:list={[
              "os-tab inline-flex items-center gap-2 rounded-lg border px-4 py-2.5 text-sm font-medium transition focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-400",
              i === 0 ? "border-brand-500/60 bg-surface text-white hover:text-white" : "border-border text-fg-muted hover:text-white",
            ]}
          >
            <Icon name={os.icon} class={os.iconClass} />
            {os.label}
          </button>
        ))
      }
    </div>

    <div class="mt-8">
      <!-- Windows -->
      <div data-tab-group="os" data-panel="windows" role="tabpanel">
        <div class="rounded-xl border border-border bg-surface/50 px-6 pb-6 pt-5 sm:px-8 sm:px-8">
          <div class="mb-4 flex items-center gap-2">
            <h3 class="text-lg font-semibold text-white">Winget</h3>
            <span class="rounded-full border border-brand-500/30 bg-brand-500/10 px-2 py-0.5 text-xs font-medium text-brand-300">Recommended</span>
          </div>
          <CodeBlock code="winget install DesktopPlus.DesktopPlus" />
          <p class="mt-3 text-sm text-fg-muted">
            Update later with <code class="rounded bg-canvas-inset px-1.5 py-0.5 font-mono text-[13px] text-fg"
              >winget upgrade DesktopPlus.DesktopPlus</code
            >.
          </p>
        </div>
        <p class="mt-4 text-sm text-fg-subtle">
          Prefer a direct download? Grab the <code class="font-mono text-[13px]">.exe</code> installer (x64 or ARM64) from the <a
            href={RELEASES_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="text-brand-400 underline underline-offset-2 hover:text-brand-300">releases page</a
          >. Manual installs don't auto-update.
        </p>
      </div>

      <!-- macOS -->
      <div data-tab-group="os" data-panel="macos" role="tabpanel" class="hidden">
        <div class="rounded-xl border border-border bg-surface/50 px-6 pb-6 pt-5 sm:px-8 sm:px-8">
          <div class="mb-4 flex items-center gap-2">
            <h3 class="text-lg font-semibold text-white">Homebrew</h3>
            <span class="rounded-full border border-brand-500/30 bg-brand-500/10 px-2 py-0.5 text-xs font-medium text-brand-300">Recommended</span>
          </div>
          <CodeBlock code="brew install desktop-plus/tap/desktop-plus" />
          <p class="mt-3 text-sm text-fg-muted">
            Update later with <code class="rounded bg-canvas-inset px-1.5 py-0.5 font-mono text-[13px] text-fg">brew update && brew upgrade</code>.
            Works on both Apple Silicon and Intel Macs.
          </p>
        </div>
        <p class="mt-4 text-sm text-fg-subtle">
          Prefer a direct download? Grab the <code class="font-mono text-[13px]">.zip</code> from the <a
            href={RELEASES_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="text-brand-400 underline underline-offset-2 hover:text-brand-300">releases page</a
          >.
        </p>
        <p class="mt-2 text-sm text-fg-subtle">
          If macOS reports it can't verify the app, open <span class="text-fg-muted">System Settings → Privacy &amp; Security</span> and click “Open Anyway”.
        </p>
      </div>

      <!-- Linux -->
      <div data-tab-group="os" data-panel="linux" role="tabpanel" class="hidden">
        <!-- Distro sub-tabs -->
        <div class="mb-6 flex flex-wrap gap-2" role="tablist" aria-label="Linux distribution">
          {
            [
              { id: "apt", label: "Debian / Ubuntu" },
              { id: "dnf", label: "Fedora / RHEL" },
              { id: "zypper", label: "openSUSE" },
              { id: "aur", label: "Arch / Manjaro" },
              { id: "flatpak", label: "Flatpak" },
            ].map((d, i) => (
              <button
                type="button"
                role="tab"
                data-tab-group="linux"
                data-tab={d.id}
                aria-selected={i === 0 ? "true" : "false"}
                class:list={[
                  "linux-tab rounded-lg border px-3.5 py-2 text-sm font-medium transition focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-400",
                  i === 0 ? "border-brand-500/60 bg-surface text-white" : "border-border text-fg-muted hover:text-fg",
                ]}
              >
                {d.label}
              </button>
            ))
          }
        </div>

        <div class="rounded-xl border border-border bg-surface/50 px-6 pb-6 pt-5 sm:px-8 sm:px-8">
          <div data-tab-group="linux" data-panel="apt">
            <h3 class="mb-4 text-lg font-semibold text-white">Debian · Ubuntu · Mint · Pop!_OS · Zorin</h3>
            <CodeBlock code={apt} />
            <p class="mt-3 text-sm text-fg-muted">
              Updates arrive through <code class="rounded bg-canvas-inset px-1.5 py-0.5 font-mono text-[13px] text-fg">apt upgrade</code> like any other
              package.
            </p>
          </div>

          <div data-tab-group="linux" data-panel="dnf" class="hidden">
            <h3 class="mb-4 text-lg font-semibold text-white">Fedora · RHEL · CentOS</h3>
            <CodeBlock code={dnf} />
            <p class="mt-3 text-sm text-fg-muted">
              Updates arrive through <code class="rounded bg-canvas-inset px-1.5 py-0.5 font-mono text-[13px] text-fg">dnf upgrade</code> like any other
              package.
            </p>
          </div>

          <div data-tab-group="linux" data-panel="zypper" class="hidden">
            <h3 class="mb-4 text-lg font-semibold text-white">openSUSE</h3>
            <CodeBlock code={zypper} />
            <p class="mt-3 text-sm text-fg-muted">
              Updates arrive through <code class="rounded bg-canvas-inset px-1.5 py-0.5 font-mono text-[13px] text-fg">zypper update</code> like any other
              package.
            </p>
          </div>

          <div data-tab-group="linux" data-panel="aur" class="hidden">
            <h3 class="mb-4 text-lg font-semibold text-white">Arch · Manjaro (AUR)</h3>
            <CodeBlock code="yay -S desktop-plus-bin" />
            <p class="mt-3 text-sm text-fg-muted">
              Or build from source by installing <code class="rounded bg-canvas-inset px-1.5 py-0.5 font-mono text-[13px] text-fg">desktop-plus</code> /
              <code class="rounded bg-canvas-inset px-1.5 py-0.5 font-mono text-[13px] text-fg">desktop-plus-git</code>.
            </p>
            <p class="mt-3 text-sm text-fg-muted">
              <code class="font-mono text-[13px]">gnome-keyring</code> is required to store credentials.
            </p>
          </div>

          <div data-tab-group="linux" data-panel="flatpak" class="hidden">
            <div class="mb-4 flex items-center gap-2">
              <h3 class="text-lg font-semibold text-white">Flatpak</h3>
              <span class="rounded-full border border-brand-500/30 bg-brand-500/10 px-2 py-0.5 text-xs font-medium text-brand-300">Any distro</span>
            </div>
            <CodeBlock code="flatpak install flathub org.desktop_plus.desktop-plus" />
            <p class="mt-3 text-sm text-fg-muted">
              Note: git hooks run inside the sandbox and can't reach tools installed on your host. If you rely on those, use a native package instead.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initTabs(group: string) {
    const tabs = document.querySelectorAll<HTMLElement>(`[data-tab-group="${group}"][data-tab]`);
    const panels = document.querySelectorAll<HTMLElement>(`[data-tab-group="${group}"][data-panel]`);
    const ON = ["border-brand-500/60", "bg-surface", "text-white"];
    const OFF = ["border-border", "text-fg-muted"];
    const names = new Set(Array.from(tabs, (t) => t.dataset.tab));

    function activate(name: string) {
      if (!names.has(name)) return;
      tabs.forEach((t) => {
        const on = t.dataset.tab === name;
        t.setAttribute("aria-selected", String(on));
        ON.forEach((c) => t.classList.toggle(c, on));
        OFF.forEach((c) => t.classList.toggle(c, !on));
      });
      panels.forEach((p) => {
        p.classList.toggle("hidden", p.dataset.panel !== name);
      });
    }

    tabs.forEach((t) => t.addEventListener("click", () => t.dataset.tab && activate(t.dataset.tab)));
    return activate;
  }

  const activateOS = initTabs("os");
  const activateLinux = initTabs("linux");

  // Detect the visitor's platform and pre-select the matching tab. Falls back to
  // the server-rendered default (Windows) when detection is inconclusive.
  function detectOS(hay: string): string | null {
    if (/android/.test(hay)) return null; // app isn't for Android
    if (/win/.test(hay)) return "windows";
    if (/mac|iphone|ipad|ipod/.test(hay)) return "macos";
    if (/linux|x11|cros/.test(hay)) return "linux";
    return null;
  }

  // Browsers rarely expose the distro, but when they do, prefer the native
  // package over the universal Flatpak.
  function detectDistro(ua: string): string {
    if (/ubuntu|debian|mint|pop!?_?os|zorin/.test(ua)) return "apt";
    if (/fedora|red ?hat|rhel|centos/.test(ua)) return "dnf";
    if (/suse|opensuse/.test(ua)) return "zypper";
    if (/arch|manjaro/.test(ua)) return "aur";
    return "apt"; // most common; safe default when the distro is unknown
  }

  const ua = navigator.userAgent.toLowerCase();
  const nav = navigator as Navigator & {
    userAgentData?: { platform?: string };
  };
  const platform = (nav.userAgentData?.platform || navigator.platform || "").toLowerCase();
  const os = detectOS(`${ua} ${platform}`);
  if (os) activateOS(os);
  if (os === "linux") activateLinux(detectDistro(ua));
</script>
