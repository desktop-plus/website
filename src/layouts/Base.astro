---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  /** Prevent search engines from indexing the page (used for utility pages). */
  noindex?: boolean;
}

const {
  title = "GH Desktop Plus: a GitHub Desktop fork for power users",
  description = "An actively-maintained, open-source fork of GitHub Desktop with commit search, multiple accounts, integration with third-party Git hosts (Bitbucket, GitLab, Codeberg), a commit graph and more. Free for Windows, macOS and Linux.",
  noindex = false,
} = Astro.props;

const site = Astro.site ?? new URL("https://desktop-plus.org");
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = new URL("/og.png", site).href;
const iconHref = new URL("/icon.png", site).href;
const repoUrl = "https://github.com/desktop-plus/desktop-plus";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "GH Desktop Plus",
  alternateName: "Desktop Plus",
  description,
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Windows, macOS, Linux",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
  isAccessibleForFree: true,
  license: "https://github.com/desktop-plus/desktop-plus/blob/main/LICENSE",
  url: site.href,
  downloadUrl: `${repoUrl}/releases/latest`,
  image: iconHref,
  softwareHelp: `${repoUrl}#readme`,
  author: {
    "@type": "Person",
    name: "Pol Rivero",
    url: "https://github.com/pol-rivero",
  },
};
---

<!doctype html>
<html lang="en" class="bg-canvas">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta
      name="keywords"
      content="GitHub Desktop fork, GitHub Desktop Linux, Git GUI, Bitbucket GUI client, GitLab desktop client, Codeberg desktop client, commit graph, open source git client, GitHub Desktop alternative"
    />
    <meta name="theme-color" content="#0d1117" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/png" href={iconHref} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="GH Desktop Plus" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="GH Desktop Plus" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {!noindex && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />}
  </head>
  <body class="min-h-dvh bg-canvas text-fg antialiased selection:bg-brand-500/30 selection:text-white">
    <slot />
  </body>
</html>
