---
import Base from '../layouts/Base.astro';

const repoUrl = 'https://github.com/DesktopPlus/desktop-plus';
---

<Base>
  <main
    class="flex min-h-dvh flex-col items-center justify-center px-6 py-20 text-center"
  >
    <div class="mb-10">
      <div class="grid place-items-center">
        <img
          src="/icon.png"
          class="h-28 w-28 drop-shadow-2xl drop-shadow-brand-900/60 sm:h-32 sm:w-32"
          alt="GH Desktop Plus logo"
        />
      </div>
    </div>

    <h1
      class="text-4xl font-semibold tracking-tight text-white sm:text-6xl"
    >
      GH Desktop Plus
    </h1>

    <p class="mt-5 max-w-xl text-balance text-base leading-relaxed text-fg-muted sm:text-lg">
      A GitHub Desktop fork with advanced functionality and improvements.
    </p>

    <p class="mt-3 text-sm text-fg-subtle">
      This page is under construction. Please check back soon.
    </p>

    <a
      href={repoUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="group mt-12 inline-flex items-center gap-2.5 rounded-lg border border-border bg-surface px-5 py-2.5 text-sm font-medium text-fg shadow-sm transition hover:border-brand-500/60 hover:bg-surface-muted focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-400"
    >
      <svg
        class="h-5 w-5 text-fg-muted transition group-hover:text-fg"
        viewBox="0 0 16 16"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
        ></path>
      </svg>
      View on GitHub
      <svg
        class="h-4 w-4 -translate-x-0.5 text-fg-subtle transition group-hover:translate-x-0 group-hover:text-fg-muted"
        viewBox="0 0 16 16"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          fill-rule="evenodd"
          d="M6.22 3.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L9.94 8 6.22 4.28a.75.75 0 0 1 0-1.06Z"
        ></path>
      </svg>
    </a>
  </main>
</Base>
