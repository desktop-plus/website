---
import Base from "../layouts/Base.astro";
---

<Base title="Authenticating…" description="Redirecting to Desktop Plus." noindex>
  <main class="flex min-h-dvh flex-col items-center justify-center px-6 py-20 text-center">
    <img src="/icon.png" class="h-20 w-20 drop-shadow-2xl drop-shadow-brand-900/60" alt="Desktop Plus logo" />

    <div id="redirect-view">
      <h1 class="mt-8 text-2xl font-semibold tracking-tight text-white">Opening Desktop Plus…</h1>

      <p class="mt-4 max-w-xl text-balance text-sm leading-relaxed text-fg-muted">
        If nothing happens, <a id="fallback-link" href="#" class="text-brand-400 underline underline-offset-2 hover:text-brand-300">click here</a> to open
        the app.
      </p>
    </div>

    <div id="error-view" class="hidden">
      <h1 class="mt-8 text-2xl font-semibold tracking-tight text-white">Authentication failed!</h1>

      <p id="error-code-wrap" class="mt-5 hidden">
        <code id="error-code" class="rounded-md border border-border bg-surface px-3 py-1.5 font-mono text-xs text-danger"></code>
      </p>

      <p id="error-description" class="mt-4 max-w-xl text-balance text-sm leading-relaxed text-fg-muted"></p>

      <p class="mt-8 text-sm text-fg-subtle">
        If the problem persists, please open a <a
          href="https://github.com/desktop-plus/desktop-plus/issues/new/choose"
          class="text-brand-400 underline underline-offset-2 hover:text-brand-300">GitHub issue</a
        >.
      </p>
    </div>
  </main>

  <script is:inline>
    const params = new URLSearchParams(window.location.search);
    const error = params.get("error");
    const errorDescription = params.get("error_description");

    if (error || errorDescription) {
      document.title = "Authentication failed";
      document.getElementById("redirect-view").classList.add("hidden");
      document.getElementById("error-view").classList.remove("hidden");

      if (error) {
        document.getElementById("error-code").textContent = error;
        document.getElementById("error-code-wrap").classList.remove("hidden");
      }
      document.getElementById("error-description").textContent =
        errorDescription || "The authentication provider reported an error. Please try again.";
    } else {
      const isDev = params.get("dev") === "1";
      params.delete("dev");

      const scheme = isDev ? "x-github-desktop-dev-auth" : "x-github-desktop-auth";
      const query = params.toString();
      const target = `${scheme}://oauth${query ? `?${query}` : ""}`;

      document.getElementById("fallback-link").href = target;
      window.location.replace(target);
    }
  </script>
</Base>
