---
import Base from '../layouts/Base.astro';
---

<Base title="Authenticating…" description="Redirecting to Desktop Plus.">
  <main
    class="flex min-h-dvh flex-col items-center justify-center px-6 py-20 text-center"
  >
    <img
      src="/icon.png"
      class="h-20 w-20 drop-shadow-2xl drop-shadow-brand-900/60"
      alt="Desktop Plus logo"
    />

    <h1 class="mt-8 text-2xl font-semibold tracking-tight text-white">
      Opening Desktop Plus…
    </h1>

    <p class="mt-4 max-w-xl text-balance text-sm leading-relaxed text-fg-muted">
      If nothing happens, <a
        id="fallback-link"
        href="#"
        class="text-brand-400 underline underline-offset-2 hover:text-brand-300"
        >click here</a
      > to open the app.
    </p>
  </main>

  <script is:inline>
    const params = new URLSearchParams(window.location.search);
    const isDev = params.get('dev') === '1';
    params.delete('dev');

    const scheme = isDev ? 'x-github-desktop-dev-auth' : 'x-github-desktop-auth';
    const query = params.toString();
    const target = `${scheme}://oauth${query ? `?${query}` : ''}`;

    document.getElementById('fallback-link').href = target;
    window.location.replace(target);
  </script>
</Base>
